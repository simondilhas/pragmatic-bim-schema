pbs:StructuralProperty a sh:NodeShape ;
    rdfs:comment "Normalized structural-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:structural_property_load_bearing pbs:structural_property_stiffness_class pbs:structural_property_strength_class ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ] ;
    sh:targetClass pbs:StructuralProperty .

pbs:ThermalProperty a sh:NodeShape ;
    rdfs:comment "Normalized thermal-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:thermal_property_u_value pbs:thermal_property_r_value pbs:thermal_property_thermal_transmittance ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ] ;
    sh:targetClass pbs:ThermalProperty .

pbs:VirtualEntity a sh:NodeShape ;
    rdfs:comment "Abstract base class for non-physical, conceptual, or informational entities." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:group_members pbs:applies_to_entities pbs:zone_type pbs:contained_entities rdf:type pbs:connects_spaces pbs:cost_category pbs:system_type pbs:serves_zones pbs:parent_level pbs:system_discipline pbs:serves_spaces pbs:parent_building pbs:material_category pbs:currency pbs:parent_legal_site pbs:cost_quantity_type pbs:parent_perimeter pbs:parent_project pbs:connection_virtual_type pbs:connection_virtual_requirement_drivers pbs:parent_zone pbs:cost_quantity_unit pbs:material_specification pbs:context_type pbs:space_type pbs:bounded_by pbs:connects_physical_elements pbs:unit_cost pbs:cost_quantity_value pbs:component_cost_items ) ;
    sh:property [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:tasks ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path pbs:messages ],
        [ sh:class pbs:CostAssembly ;
            sh:description "Aggregated unit prices associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path pbs:cost_assemblies ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path pbs:status ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:documents ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:revision ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:CostItem ;
            sh:description "Cost items associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:cost_items ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:created_at ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:description ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:meaning_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:name ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:decisions ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:materials ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:localized_descriptions ] ;
    sh:targetClass pbs:VirtualEntity .

pbs:Change a sh:NodeShape ;
    rdfs:comment """Detected difference for one subject between two revisions. Supports IFC model diffs, document/text diffs, and schema-entity field changes.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:PropertyDelta ;
            sh:description "Field-level differences detected between the two revision states." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:property_delta ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:affected_subject_type ],
        [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:triggered_process ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:triggered_task ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:to_revision ],
        [ sh:class pbs:StateRef ;
            sh:description "Content state pointer at the target revision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:to_state_ref ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:document_storage_link ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:created ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:affected_subject_path ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:affected_subject_id ],
        [ sh:description "Severity or category of change detected between two revisions." ;
            sh:in ( pbs:change_kind_unchanged pbs:change_kind_minor pbs:change_kind_major pbs:change_kind_rewritten pbs:change_kind_new pbs:change_kind_deleted ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:change_kind ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path pbs:change_source ],
        [ sh:class pbs:StateRef ;
            sh:description "Content state pointer at the source revision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:from_state_ref ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:from_revision ] ;
    sh:targetClass pbs:Change .

pbs:Company a sh:NodeShape ;
    rdfs:comment "Organization, company, or legal entity participating in the project or asset lifecycle." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:PostalAddress ;
            sh:description "Structured postal or physical addresses associated with this agent." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path pbs:postal_addresses ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:metadata ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path pbs:localized_names ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path pbs:created_at ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:id ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:tasks ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:revision ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 21 ;
            sh:path pbs:status ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path pbs:localized_descriptions ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:decisions ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:geometry_representations ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:description ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path pbs:messages ],
        [ sh:class pbs:ContactPoint ;
            sh:description "Structured communication channels and profiles associated with this agent." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path pbs:contact_points ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:documents ] ;
    sh:targetClass pbs:Company .

pbs:PropertyDelta a sh:NodeShape ;
    rdfs:comment """Field-level difference between two revision states. Supports IFC attributes, PropertySets, schema slots, document fields, and text spans.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:string ;
            sh:description "New value serialized as text. Absent or null for deleted subjects or fields." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:to_value ],
        [ sh:datatype xsd:string ;
            sh:description """Canonical path to the changed field. Examples: Pset_WallCommon.FireRating, IfcWall.Name, description, section.4.2.requirement_3, body:char_offset:1204-1389.
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:property_path ],
        [ sh:datatype xsd:string ;
            sh:description "Prior value serialized as text. Absent or null for new subjects or fields." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:from_value ],
        [ sh:description "Classification of the property path for downstream diff interpretation." ;
            sh:in ( pbs:property_path_kind_ifc_attribute pbs:property_path_kind_ifc_pset pbs:property_path_kind_schema_slot pbs:property_path_kind_document_field pbs:property_path_kind_text_span ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_path_kind ],
        [ sh:datatype xsd:string ;
            sh:description "IFC attribute name when property_path_kind is ifc_attribute (for example Name, GlobalId)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:ifc_attribute_name ] ;
    sh:targetClass pbs:PropertyDelta .

pbs:ScheduleDependency a sh:NodeShape ;
    rdfs:comment "Precedence relationship between two schedule items, optionally with lag." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:ScheduleItem ;
            sh:description "Schedule item whose timing is constrained by the predecessor item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:successor_item ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path pbs:messages ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:id ],
        [ sh:class pbs:ScheduleTemplate ;
            sh:description "Parent schedule template this item or dependency belongs to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:schedule_template ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:description ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path pbs:tasks ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:decisions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
