pbs:StateRef a sh:NodeShape ;
    rdfs:comment """Pointer to a content state at a specific revision. Covers IFC models, geometry payloads, documents, and extracted text.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI, path, or content hash identifying the stored content state." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:state_ref ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable label (for example LOD300 export, Spec v3 draft)." ;
