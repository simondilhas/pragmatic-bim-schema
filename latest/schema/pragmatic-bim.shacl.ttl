@prefix bot: <https://w3id.org/bot#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ifcowl: <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix pbs: <https://schema.pragmaticbim.ch/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pbs:AbstractCostRecord a sh:NodeShape ;
    rdfs:comment "Abstract base for reusable cost record fields shared by atomic and aggregated cost records." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:component_cost_items rdf:type ) ;
    sh:property [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path pbs:messages ],
        [ sh:datatype xsd:double ;
            sh:description "Unit cost for this cost item." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:unit_cost ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:materials ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path pbs:metadata ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:meaning_uri ],
        [ sh:description "Quantity type used as basis for this cost calculation." ;
            sh:in ( ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityVolume ifcowl:IfcQuantityVolume ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path pbs:cost_quantity_type ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path pbs:documents ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path pbs:tasks ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 29 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:string ;
            sh:description "Unit of the cost quantity value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:cost_quantity_unit ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:CostAssembly ;
            sh:description "Aggregated unit prices associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path pbs:cost_assemblies ],
        [ sh:datatype xsd:double ;
            sh:description "Quantity magnitude used as basis for this cost calculation." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:cost_quantity_value ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path pbs:revision ],
        [ sh:class pbs:CostItem ;
            sh:description "Cost items associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:cost_items ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:description ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:geometry_representations ],
        [ sh:datatype xsd:string ;
            sh:description "Cost category label kept intentionally open pending classification-backed modeling." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:cost_category ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:localized_names ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 4217 currency code (for example EUR, USD)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:currency ;
            sh:pattern "^[A-Z]{3}$" ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:name ],
        [ sh:class pbs:Entity ;
            sh:description "Entities this cost item applies to." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:applies_to_entities ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path pbs:decisions ] ;
    sh:targetClass pbs:AbstractCostRecord .

pbs:AcousticProperty a sh:NodeShape ;
    rdfs:comment "Normalized acoustic-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:acoustic_property_rating_db pbs:acoustic_property_impact_sound_rating_db pbs:acoustic_property_airborne_sound_rating_db ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ] ;
    sh:targetClass pbs:AcousticProperty .

pbs:Boundary a sh:NodeShape ;
    rdfs:comment "Physical element acting as a boundary treatment (for example covering)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path pbs:localized_descriptions ],
        [ sh:class pbs:BuiltAssetContext ;
            sh:description "Parent building context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:parent_building ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:decisions ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:Space ;
            sh:description "Space bounded by this boundary element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path pbs:bounded_space ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path pbs:localized_names ],
        [ sh:description "Classification of boundary element (e.g., covering)." ;
            sh:in ( ifcowl:IfcCoveringTypeEnum.FLOORING ifcowl:IfcCoveringTypeEnum.CEILING ifcowl:IfcCoveringTypeEnum.CLADDING ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:boundary_type ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path pbs:messages ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:metadata ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 23 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:description ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:name ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:documents ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:created_at ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:id ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:parent_level ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path pbs:revision ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:tasks ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:modified_at ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:classifications ] ;
    sh:targetClass pbs:Boundary .

pbs:BuildingContext a sh:NodeShape ;
    rdfs:comment "Spatial context node constrained to building semantics." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path pbs:metadata ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path pbs:materials ],
        [ sh:class pbs:Entity ;
            sh:description "Zone members; may include spaces, separations, systems, etc." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path pbs:group_members ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:ZoneContext ;
            sh:description "Parent zone context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:parent_zone ],
        [ sh:class pbs:LegalSiteContext ;
            sh:description "Parent legal site context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path pbs:parent_legal_site ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:localized_descriptions ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:parent_level ],
        [ sh:description "Classification of context entity (project, perimeter, legal_site, building, civil_structure, level, zone)." ;
            sh:in ( ifcowl:IfcProject ifcowl:IfcSite pbs:LegalSiteContext bot:Building ifcowl:IfcCivilElement bot:Storey bot:Zone ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:context_type ],
        [ sh:description "Optional zone classification; intended for SpatialContext nodes where context_type is zone." ;
            sh:in ( ifcowl:IfcSpatialZone ifcowl:IfcSpatialZone ifcowl:IfcSpatialZone ifcowl:IfcGroup ifcowl:IfcSpatialZone ifcowl:IfcSpatialZone ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path pbs:zone_type ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:CostAssembly ;
            sh:description "Aggregated unit prices associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:cost_assemblies ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path pbs:messages ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path pbs:tasks ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:id ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path pbs:documents ],
        [ sh:class pbs:BuiltAssetContext ;
            sh:description "Parent building context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:parent_building ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path pbs:decisions ],
        [ sh:class pbs:PerimeterContext ;
            sh:description "Parent perimeter context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:parent_perimeter ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path pbs:revision ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path pbs:status ],
        [ sh:class pbs:CostItem ;
            sh:description "Cost items associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:cost_items ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pbs:description ],
        [ sh:class pbs:ProjectContext ;
            sh:description "Parent project context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:parent_project ] ;
    sh:targetClass pbs:BuildingContext .

pbs:ChangeSet a sh:NodeShape ;
    rdfs:comment """Batch of Change records produced by comparing two model or document revisions.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:to_revision ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:from_revision ],
        [ sh:class pbs:StateRef ;
            sh:description "Optional baseline IFC model state for the comparison that produced this changeset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path pbs:ifc_state_ref ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this changeset was produced." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:created ],
        [ sh:class pbs:StateRef ;
            sh:description "Optional baseline document states for the comparison that produced this changeset." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path pbs:document_state_refs ],
        [ sh:class pbs:Agent ;
            sh:description "Agent or system that produced this changeset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path prov:wasAttributedTo ],
        [ sh:class pbs:Change ;
            sh:description "Change records included in this batch." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:changes ] ;
    sh:targetClass pbs:ChangeSet .

pbs:CivilStructureContext a sh:NodeShape ;
    rdfs:comment "Spatial context node constrained to civil structure semantics." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
