pbs:Entity a sh:NodeShape ;
    rdfs:comment "Common base class for all schema entities." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:group_members pbs:applies_to_entities pbs:schedule_template rdf:type pbs:connects_spaces pbs:predecessor_item pbs:system_type <http://schema.org/headline> pbs:serves_zones pbs:connection_physical_requirement_drivers <http://schema.org/dateSent> pbs:actual_start_at pbs:system_discipline pbs:serves_spaces pbs:parent_building pbs:parent_system pbs:equipment_type pbs:connection_physical_type pbs:planned_start_at pbs:contact_points pbs:transport_medium pbs:cost_quantity_type pbs:separator_requirement_drivers pbs:parent_perimeter pbs:milestone_at pbs:schedule_dependencies pbs:material_specification pbs:context_type pbs:parent_space pbs:unit_cost dcterms:type pbs:cost_quantity_value pbs:cost_assemblies pbs:zone_type pbs:contained_entities pbs:cost_category pbs:separator_wall_type pbs:parent_level pbs:bounded_space pbs:materials pbs:material_category pbs:boundary_type pbs:currency pbs:parent_legal_site <http://schema.org/text> pbs:lag_days pbs:postal_addresses pbs:separator_slab_type pbs:actual_finish_at pbs:separates_spaces pbs:parent_project <http://schema.org/recipient> pbs:connection_virtual_type pbs:scheduled_entities pbs:connection_virtual_requirement_drivers <http://schema.org/sender> pbs:belongs_to_company pbs:parent_zone pbs:cost_quantity_unit pbs:schedule_items pbs:planned_finish_at pbs:dependency_type pbs:space_type pbs:successor_item pbs:bounded_by pbs:connects_physical_elements pbs:separates_levels pbs:cost_items pbs:component_cost_items ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
