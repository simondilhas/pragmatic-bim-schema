pbs:SpatialContext a sh:NodeShape ;
    rdfs:comment "Context node used to represent project, perimeter, legal site, built asset, level, or zone." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Classification of context entity (project, perimeter, legal_site, building, civil_structure, level, zone)." ;
            sh:in ( ifcowl:IfcProject ifcowl:IfcSite pbs:LegalSiteContext bot:Building ifcowl:IfcCivilElement bot:Storey bot:Zone ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:context_type ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
